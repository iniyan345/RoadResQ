# ================================================================
# RoadResQ — Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ================================================================

# ---- Server ----
PORT=5000
# Set to your deployed frontend URL in production
CLIENT_ORIGIN=http://localhost:5000

# ---- MongoDB Atlas ----
# Get from: Atlas > Connect > Drivers > Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/roadresq?retryWrites=true&w=majority

# ---- Firebase Admin SDK (Server-side) ----
# Get from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# These values are SERVER-ONLY secrets — never expose to the browser.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep the \n escapes literal — the code un-escapes them at runtime
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n"

# ---- Firebase Client SDK (Browser-facing — safe to expose) ----
# Get from: Firebase Console > Project Settings > Your Apps > Web App > SDK setup
FIREBASE_API_KEY=AIzaSy-your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
# FIREBASE_MESSAGING_SENDER_ID is optional
FIREBASE_MESSAGING_SENDER_ID=123456789012

# ---- Bcrypt (legacy email/password fallback) ----
BCRYPT_SALT_ROUNDS=10

# ---- Email / SMTP (Nodemailer — for emergency contact alerts) ----
# Using SendGrid SMTP relay:
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.your_sendgrid_api_key_here
EMAIL_FROM="RoadResQ <no-reply@roadresq.app>"

# ---- Google Maps API Key (Frontend — restrict to your domain) ----
# Get from: Google Cloud Console > APIs & Services > Credentials
# Restrict to: Maps JavaScript API, Directions API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
